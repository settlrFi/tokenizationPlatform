ORACLE_UPDATER_ADDRESS="0x0000000000000000000000000000000000000000"
MAKER_ADDRESS="0x0000000000000000000000000000000000000000"
DEPOSITARY_ADDRESS="0x0000000000000000000000000000000000000000"
PLATFORM_ADDRESS="0x0000000000000000000000000000000000000000"
TREASURY_ADDRESS="0x0000000000000000000000000000000000000000"
CORP_ACTION_OPERATOR_ADDRESS="0x0000000000000000000000000000000000000000"

# These are written automatically by the deploy scripts.
FACTORY_ADDRESS=""
