SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_KEY"
SEPOLIA_PRIVATE_KEYS="0xDEPLOYER_PRIVATE_KEY,0xCOMPLIANCE_PRIVATE_KEY,0xUPDATER_PRIVATE_KEY"
ETHERSCAN_API_KEY="YOUR_ETHERSCAN_API_KEY"
SEPOLIA_ORACLE_UPDATER_PRIVATE_KEY=""
ORACLE_BOT_PRIVATE_KEY=""
PRICE_FETCH_TIMEOUT_MS=8000
PRICE_FETCH_RETRIES=2
EURUSD_FALLBACK=1.08
PRICE_FALLBACKS="AAPL=200,MSFT=350,ISP.MI=7"

CHAIN_ID=11155111

# Optional role addresses. If omitted, the scripts fall back to the loaded signer at that index,
# or to the deployer when no extra signer is available.
